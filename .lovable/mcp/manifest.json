{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://nvckrwlvwmgcptzctrsz.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "interactup-os-mcp",
      "version": "0.1.0",
      "title": "InteractUp OS"
    },
    "tools": [
      {
        "name": "list_events",
        "title": "List events",
        "description": "List InteractUp events (competitions, meetups). Filter by upcoming/past and optionally include draft events (staff only see drafts).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "scope": {
              "default": "upcoming",
              "description": "Which events to return.",
              "type": "string",
              "enum": [
                "upcoming",
                "past",
                "all"
              ]
            },
            "limit": {
              "default": 10,
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "include_drafts": {
              "default": false,
              "description": "Include draft events. Only visible to staff via RLS.",
              "type": "boolean"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "verify_certificate",
        "title": "Verify certificate",
        "description": "Look up an InteractUp certificate by its unique code (format like IUP-XXXX-XXXX) and return the recipient, event, and issue date.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "minLength": 3,
              "description": "The certificate code printed on the certificate."
            }
          },
          "required": [
            "code"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_my_certificates",
        "title": "List my certificates",
        "description": "List certificates issued to the signed-in InteractUp user (matched by recipient email).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_my_tasks",
        "title": "List my tasks",
        "description": "List open tasks assigned to the signed-in InteractUp user.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "include_done": {
              "default": false,
              "type": "boolean"
            },
            "limit": {
              "default": 20,
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "create_event",
        "title": "Create event",
        "description": "Create a new InteractUp event (competition, meetup, etc.). Requires staff (admin or team_member) role — RLS will reject other callers. Defaults to draft; set publish=true to publish immediately.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 2
            },
            "description": {
              "type": "string"
            },
            "event_date": {
              "description": "ISO date (YYYY-MM-DD). Optional.",
              "type": "string"
            },
            "venue": {
              "type": "string"
            },
            "prize_money": {
              "type": "number",
              "minimum": 0
            },
            "publish": {
              "default": false,
              "type": "boolean"
            }
          },
          "required": [
            "name"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
